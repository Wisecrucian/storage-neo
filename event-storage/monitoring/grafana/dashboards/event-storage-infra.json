      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "id": 5,
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"event-storage-server\"}[1m]))", "legendFormat": "HTTP RPS", "refId": "A" }
      ],
      "title": "HTTP Throughput (RPS)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "id": 6,
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"event-storage-server\"}[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"event-storage-server\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B" }
      ],
      "title": "HTTP Latency (p50 / p95)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
